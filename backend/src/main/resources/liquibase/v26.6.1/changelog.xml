<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd"
                   logicalFilePath="v26.6.1/changelog.xml">

    <changeSet id="v26.6.1-alter-transaction-add-location" author="petr-panteleyev@yandex.ru">
        <sql>
            ALTER TABLE transaction ADD COLUMN IF NOT EXISTS location VARCHAR NOT NULL DEFAULT '';
        </sql>
        <rollback>
            <sql>
                ALTER TABLE transaction DROP COLUMN IF EXISTS location
            </sql>
        </rollback>
    </changeSet>
</databaseChangeLog>
